{
  "name": "code-hive",
  "version": "0.1.0",
  "description": "AI CLI session manager for macOS",
  "type": "module",
  "bin": {
    "hive": "./dist/cli/index.js"
  },
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.electron.json",
    "build:cli": "tsc",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev": "tsc --watch",
    "app": "npm run build:electron && electron .",
    "hive": "node dist/cli/index.js",
    "dist": "npm run build && electron-builder --mac",
    "dist:dmg": "npm run build && electron-builder --mac dmg",
    "dist:zip": "npm run build && electron-builder --mac zip"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "menubar": "^9.5.2",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  },
  "build": {
    "appId": "com.virgil2019.code-hive",
    "productName": "Code Hive",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/electron/**/*",
      "electron/preload.cjs",
      "renderer/**/*",
      "hooks/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "hooks/claude-code-hook.sh",
        "to": "hooks/claude-code-hook.sh"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
